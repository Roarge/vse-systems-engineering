// As-Is current state (contingent subset, survey-populated).
//
// Generated by /vse-setup brownfield as-is survey on {{DATE}}.
//
// This file is the survey-populated counterpart to _template.sysml in
// the same directory. /vse-setup writes here when the user accepted
// the as-is survey and at least one element was classified as
// CONTINGENT. If the survey was skipped or produced no contingent
// elements, _template.sysml stands alone.
//
// Promotion of a contingent element to Base Architecture requires a
// Change Request (see _template.sysml for the promotion path).

package <{{PROJECT_SHORT_CODE}}_AsIs> {{PROJECT_NAME}}_AsIs {

    private import VSE_Library::ConfigItem;
    private import VSE_Library::CIState;
    private import {{PROJECT_NAME}}_BaseArchitecture::*;

    // {{AS_IS_CONTINGENT_PART_DEFS}}
    //
    // Per contingent row from the as-is survey, /vse-setup emits one
    // part def in this body, with the following shape:
    //
    //     part def <ElementName> {
    //         @ConfigItem {
    //             ciId = "AS-IS-<NN>";
    //             baselineId = "BL-AS-IS-CURRENT-0.1";
    //             ciState = CIState::Proposed;
    //             owner = "{{AUTHOR}}";
    //         }
    //         attribute version : String = "<declared-version>";
    //         attribute mandateSource : String = "(contingent: project owns the choice)";
    //     }
    //
    // No `require constraint` clauses are emitted at survey time.
    // The user adds them later via @architecture-design once the
    // engineering implications of each contingent choice are
    // understood, or when a contingent element is being promoted to
    // mandated under a Change Request.
}
